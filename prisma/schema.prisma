// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// NEXTAUTH MODELS
// ------------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id        String     @id @default(cuid())
  name      String?
  username  String?    @unique
  email     String?    @unique
  password  String?
  image     String?
  role      Role       @default(USER)
  status    UserStatus @default(INACTIVE)
  cardLimit Int        @default(3) @map("card_limit")
  accounts  Account[]
  sessions  Session[]

  scrapingCards ScrapingCard[]
  orders        Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ------------------------------------------------------
// TELOCOMENTO BUSINESS MODELS
// ------------------------------------------------------

model ScrapingCard {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  keyword   String // Palabra clave para la búsqueda en Facebook
  context   String?    @db.Text // Contexto adicional para filtrar publicaciones relevantes
  status    CardStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  publications Publication[]

  @@map("scraping_cards")
}

enum CardStatus {
  ACTIVE
  INACTIVE
}

model Publication {
  id             String       @id @default(cuid())
  scrapingCardId String       @map("scraping_card_id")
  sourceUrl      String       @map("source_url")
  authorName     String?      @map("author_name")
  content        String?      @db.Text
  imageUrl       String?      @map("image_url")
  publishedAt    DateTime     @map("published_at")
  sentiment      Sentiment    @default(NEUTRAL)
  reviewStatus   ReviewStatus @default(PENDING)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  scrapingCard ScrapingCard @relation(fields: [scrapingCardId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@map("publications")
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Order {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  publicationId String      @map("publication_id")
  intent        Intent // POSITIVE (apoyar) or NEGATIVE (atacar)
  notes         String?     @db.Text
  status        OrderStatus @default(DRAFT)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  comments    Comment[]

  @@map("orders")
}

enum Intent {
  POSITIVE
  NEGATIVE
}

enum OrderStatus {
  DRAFT
  GENERATED
  ACTIVATED
  IN_PROGRESS
  COMPLETED
  ERROR
}

model Comment {
  id          String        @id @default(cuid())
  orderId     String        @map("order_id")
  content     String        @db.Text
  status      CommentStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  commentedAt DateTime?     @map("commented_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("comments")
}

enum CommentStatus {
  PENDING
  SENT
  PUBLISHED
  ERROR
}
